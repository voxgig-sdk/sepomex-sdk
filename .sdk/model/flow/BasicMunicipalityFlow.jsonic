# BasicMunicipalityFlow

main: kit: flow: BasicMunicipalityFlow:
{
  entity: "municipality",
  kind: "basic",
  name: "BasicMunicipalityFlow",
  step: [
    {
      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "municipality_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "municipality_ref01",
        srcdatavar: "municipality_ref01_data",
        suffix: "_dt0"
      }

      match: {
        id: "municipality01"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-municipality_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicMunicipalityFlow"
}